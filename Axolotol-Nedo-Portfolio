<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Axolotol751 | 3D Artist</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-color: #0d1117;
            --card-bg: rgba(22, 27, 34, 0.7);
            --card-border: rgba(48, 54, 61, 0.5);
            --text-primary: #e6edf3;
            --text-secondary: #8b949e;
            --accent-color: #ff80ab;
            --accent-glow: rgba(255, 128, 171, 0.3);
            --glass-blur: blur(20px);
        }

        [data-theme="oled"] {
            --bg-color: #000000;
            --card-bg: rgba(20, 20, 20, 0.8);
            --card-border: rgba(255, 255, 255, 0.08);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans', Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            line-height: 1.6;
            transition: background-color 0.3s ease;
        }

        .container {
            width: 100%;
            max-width: 900px;
            position: relative;
        }

        /* Controls */
        .controls {
            position: absolute;
            top: -60px;
            right: 0;
            display: flex;
            gap: 12px;
            z-index: 100;
        }

        .control-btn {
            background: var(--card-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 8px 16px;
            color: var(--text-primary);
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .control-btn:hover {
            border-color: var(--accent-color);
            box-shadow: 0 0 20px var(--accent-glow);
            transform: translateY(-2px);
        }

        /* Bento Grid */
        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: 180px;
            gap: 20px;
        }

        .card {
            background: var(--card-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInUp 0.6s ease forwards;
        }

        .card:nth-child(1) { animation-delay: 0.1s; }
        .card:nth-child(2) { animation-delay: 0.2s; }
        .card:nth-child(3) { animation-delay: 0.3s; }
        .card:nth-child(4) { animation-delay: 0.4s; }
        .card:nth-child(5) { animation-delay: 0.5s; }
        .card:nth-child(6) { animation-delay: 0.6s; }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card:hover {
            transform: scale(1.03);
            box-shadow: 0 0 40px var(--accent-glow), 0 10px 40px rgba(0,0,0,0.3);
            border-color: var(--accent-color);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), var(--accent-glow), transparent 50%);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

        .card:hover::before {
            opacity: 1;
        }

        /* Hero Card */
        .hero {
            grid-column: span 2;
            grid-row: span 2;
            justify-content: flex-end;
            align-items: flex-start;
            background: linear-gradient(135deg, rgba(22, 27, 34, 0.9) 0%, rgba(255, 128, 171, 0.1) 100%);
        }

        .hero h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 8px;
            background: linear-gradient(135deg, #fff 0%, var(--accent-color) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero .subtitle {
            font-size: 1.1rem;
            color: var(--accent-color);
            font-weight: 500;
            margin-bottom: 8px;
        }

        .hero .role {
            font-size: 1rem;
            color: var(--text-secondary);
            font-weight: 400;
        }

        /* Showcase Tile */
        .showcase {
            grid-column: span 2;
            grid-row: span 2;
            padding: 0;
            position: relative;
            background-image: url('render.jpg');
            background-size: cover;
            background-position: center;
        }

        .showcase::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(13, 17, 23, 0.9) 0%, transparent 50%);
            border-radius: 24px;
        }

        .showcase-content {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 24px;
            z-index: 2;
        }

        .showcase h2 {
            font-size: 1.5rem;
            margin-bottom: 8px;
            color: var(--text-primary);
        }

        .showcase p {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* Social Cards */
        .social-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .social-card svg {
            width: 40px;
            height: 40px;
            color: var(--accent-color);
            transition: transform 0.3s;
        }

        .card:hover .social-card svg {
            transform: scale(1.1);
        }

        .github svg { color: var(--accent-color); }
        .telegram svg { color: var(--accent-color); }

        /* About Card */
        .about {
            grid-column: span 2;
            justify-content: flex-start;
            align-items: flex-start;
            text-align: left;
        }

        .about h2 {
            font-size: 1.5rem;
            margin-bottom: 12px;
            color: var(--accent-color);
        }

        .about p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.7;
        }

        /* Projects Card */
        .projects {
            grid-column: span 2;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(90deg, var(--card-bg) 0%, rgba(255, 128, 171, 0.08) 100%);
        }

        .projects-content {
            flex: 1;
        }

        .projects h2 {
            font-size: 1.5rem;
            margin-bottom: 8px;
            color: var(--accent-color);
        }

        .projects p {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .projects-arrow {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255, 128, 171, 0.1);
            border: 1px solid var(--accent-color);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .card:hover .projects-arrow {
            background: var(--accent-color);
            transform: translateX(5px);
        }

        .projects-arrow svg {
            width: 24px;
            height: 24px;
            color: var(--accent-color);
            transition: color 0.3s;
        }

        .card:hover .projects-arrow svg {
            color: var(--bg-color);
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .controls {
                position: fixed;
                top: 20px;
                right: 20px;
                background: var(--card-bg);
                backdrop-filter: var(--glass-blur);
                border-radius: 12px;
                padding: 4px;
            }

            .bento-grid {
                grid-template-columns: 1fr 1fr;
                grid-auto-rows: 160px;
                gap: 16px;
                margin-top: 60px;
            }

            .hero {
                grid-column: span 2;
                grid-row: span 2;
            }

            .hero h1 {
                font-size: 2rem;
            }

            .showcase {
                grid-column: span 2;
                grid-row: span 2;
            }

            .about {
                grid-column: span 2;
                grid-row: span 2;
                min-height: 200px;
            }

            .projects {
                grid-column: span 2;
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .github, .telegram {
                grid-column: span 1;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 16px;
            }

            .bento-grid {
                gap: 12px;
                grid-auto-rows: 140px;
            }

            .card {
                padding: 20px;
                border-radius: 20px;
            }

            .hero h1 {
                font-size: 1.75rem;
            }

            .hero .subtitle {
                font-size: 1rem;
            }

            .control-btn {
                padding: 6px 12px;
                font-size: 0.85rem;
            }
        }

        ::selection {
            background: var(--accent-color);
            color: var(--bg-color);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Controls -->
        <div class="controls">
            <button class="control-btn" id="langToggle" onclick="toggleLanguage()">RU</button>
            <button class="control-btn" id="themeToggle" onclick="toggleTheme()">OLED</button>
        </div>

        <div class="bento-grid">
            <!-- Hero Card -->
            <div class="card hero">
                <h1>Axolotol751</h1>
                <div class="subtitle" data-ru="Minecraft 3D Artist | Blender" data-en="Minecraft 3D Artist | Blender">
                    Minecraft 3D Artist | Blender
                </div>
                <div class="role" data-ru="Креативные визуализации блоков" data-en="Creative block visualizations">
                    Креативные визуализации блоков

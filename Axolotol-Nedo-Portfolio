            </div>

            <!-- Showcase Tile -->
            <div class="card showcase">
                <div class="showcase-content">
                    <h2 data-ru="Рендеры" data-en="Renders">Рендеры</h2>
                    <p data-ru="Кинематографичные сцены Minecraft" data-en="Cinematic Minecraft scenes">Кинематографичные сцены Minecraft</p>

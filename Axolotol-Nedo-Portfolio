            </div>

            <!-- Projects -->
            <a href="#" target="_blank" class="card projects">
                <div class="projects-content">
                    <h2 data-ru="Мои работы" data-en="My Projects">Мои работы</h2>
                    <p data-ru="Связаться через Telegram" data-en="Contact via Telegram">Связаться через Telegram</p>
                </div>
                <div class="projects-arrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
